{
   "name": "restaurant",
   "version": "0.0.1",
   "description": "Awesome project developed with TypeORM.",
   "type": "commonjs",
   "devDependencies": {
      "@types/chai": "^5.2.0",
      "@types/express": "^5.0.5",
      "@types/jest": "^29.5.14",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/mocha": "^10.0.10",
      "@types/node": "^16.18.112",
      "@types/passport": "^1.0.17",
      "@types/supertest": "^6.0.2",
      "chai": "^5.2.0",
      "cross-env": "^10.1.0",
      "jest": "^29.7.0",
      "mocha": "^11.1.0",
      "supertest": "^7.1.0",
      "ts-jest": "^29.3.1",
      "ts-node": "^10.9.2",
      "ts-node-dev": "^2.0.0",
      "typescript": "4.5.2"
   },
   "dependencies": {
      "@types/multer": "^1.4.12",
      "axios": "^1.11.0",
      "bcrypt": "^5.1.1",
      "cors": "^2.8.5",
      "dotenv": "^16.6.1",
      "express": "^4.21.2",
      "express-session": "^1.18.2",
      "jsonwebtoken": "^9.0.2",
      "multer": "^1.4.5-lts.1",
      "mysql": "^2.18.1",
      "node-cron": "^4.2.1",
      "passport": "^0.7.0",
      "passport-google-oauth20": "^2.0.0",
      "reflect-metadata": "^0.1.14",
      "typeorm": "0.3.20"
   },
   "scripts": {
      "dev": "cross-env NODE_ENV=development ts-node-dev --transpile-only --respawn src/index.ts",
      "build": "tsc",
      "start": "cross-env NODE_ENV=production node dist/index.js",
      "typeorm": "cross-env NODE_ENV=development typeorm-ts-node-commonjs",
      "migration:generate": "cross-env NODE_ENV=development typeorm-ts-node-commonjs migration:generate src/migrations/migrations -d src/data-source.ts",
      "migration:run": "cross-env NODE_ENV=development typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
      "migration:revert": "cross-env NODE_ENV=development typeorm-ts-node-commonjs migration:revert -d src/data-source.ts"
   }
}
